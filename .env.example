ADMIN_PASSPHRASE=change-this-to-a-long-random-passphrase
SESSION_SECRET=change-this-to-a-long-random-session-secret
SESSION_TTL_SECONDS=28800
PORT=8000

# Supabase is enabled automatically when these two values are set.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=vault-uploads
